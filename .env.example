# =============================================
# Ruang Cek Fakta — Environment Variables
# =============================================
# Salin file ini menjadi `.env.local` dan isi dengan nilai yang sesuai.
# Jangan pernah commit file `.env.local` ke version control!
#
# Cara setup:
# 1. cp .env.example .env.local
# 2. Isi nilai di bawah dengan kredensial dari Supabase Dashboard
#    (Settings → API)

# ── Supabase ──────────────────────────────────
# URL project Supabase Anda
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Anon/Public key Supabase (aman untuk di-expose ke browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key-here
